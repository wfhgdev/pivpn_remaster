#!/bin/bash

### Constantes
CHECK_PKG_INSTALLED='dpkg-query -s'
scriptDir="/opt/pivpn"

### Funciones
err() {
  echo "[$(date +'%Y-%m-%dT%H:%M:%S%z')]: $*" >&2
}

uninstallServer() {
  ${SUDO} "${scriptDir}/uninstall.sh"
  exit "${?}"
}

backup() {
  ${SUDO} "${scriptDir}/backup.sh"
  exit "${?}"
}

showHelp() {
  echo "::: Para pasar al comando pivpn para cada protocolo"
  echo ":::"
  echo "::: Uso: pivpn wg  <command> [option]"
  echo "::: Uso: pivpn ovpn <command> [option]"
  echo ":::"
  echo ":::  -h,  help             Mostrar este diálogo de ayuda"
  echo ":::  -u,  uninstall        ¡Desinstala PiVPN de tu sistema!"
  echo ":::  -bk, backup           Realizar una copia de seguridad de las configuraciones VPN y los perfiles de usuario"
  exit 0
}

### Script
# Debes ser usuario root para usar esta herramienta.
if [[ "${EUID}" -ne 0 ]]; then
  if ${CHECK_PKG_INSTALLED} sudo &> /dev/null; then
    export SUDO="sudo"
  else
    err "::: Por favor instale sudo o ejecute esto como root.."
    exit 1
  fi
fi

if grep -qsEe "^NAME\=['\"]?Alpine[a-zA-Z ]*['\"]?$" /etc/os-release; then
  CHECK_PKG_INSTALLED='apk --no-cache info -e'
fi

if [[ "$#" == 0 ]]; then
  showHelp
fi

# Gestionar la redirección a funciones específicas en función de los argumentos.
case "${1}" in
  wg)
    "${scriptDir}/wireguard/pivpn.sh" "${@:2}"
    ;;
  ovpn)
    "${scriptDir}/openvpn/pivpn.sh" "${@:2}"
    ;;
  "-h" | "help")
    showHelp
    ;;
  "-u" | "uninstall")
    uninstallServer
    ;;
  "-bk" | "backup")
    backup
    ;;
  *)
    showHelp
    ;;
esac
